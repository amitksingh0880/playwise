{
  "compilerOptions": {
    "module": "commonjs",
    "target": "es2020",
    "lib": ["es2020", "dom"],
    "types": ["chrome"],
    "outDir": "./",
    "rootDir": "./",
    "sourceMap": false,
    "strict": false,
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "ignoreDeprecations": "6.0"
  },
  "include": ["background.ts", "content.ts"],
  "exclude": ["node_modules"]
}
